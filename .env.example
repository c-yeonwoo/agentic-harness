# ── GitHub ──
GH_TOKEN=                  # PAT — repo + write + workflow scope. project 별 PAT 도 OK (PALETTE_AGENT_PAT 등)

# ── LLM provider ──
LLM_PROVIDER=openai        # openai | anthropic
OPENAI_API_KEY=            # sk-...
ANTHROPIC_API_KEY=         # sk-ant-... (anthropic 사용 시)
ANTHROPIC_BASE_URL=        # optional: 사내 gateway

# ── 모델 ──
EXECUTOR_MODEL=gpt-5.3-codex
REVIEWER_MODEL=gpt-5.3-codex
EXECUTOR_COST_CAP=1.50                          # ReAct 1회 비용 cap (USD)

# ── orchestrator ──
MAX_PARALLEL_EXECUTORS=2
MAX_PARALLEL_REVIEWERS=2
POLL_INTERVAL=30           # ah run daemon 의 poll 주기 (Hermes cron 쓰면 무관)

# ── notification ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
