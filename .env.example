# ── GitHub ──
# Backend 자동 분기 (ADR-013):
#   cwd=~/dev-private/* → HTTP (PROJECT_AGENT_PAT 사용)
#   cwd=~/dev/*         → gh CLI 사용
#   GH_BACKEND=http|cli 로 override 가능
GH_TOKEN=                  # gh CLI 인증 fallback (HTTP 의 fallback 으로도 쓰임)
PALETTE_AGENT_PAT=         # HTTP backend — c-yeonwoo/palette
# LORE_AGENT_PAT=          # HTTP backend — c-yeonwoo/lore (등 — {REPO_BASE_UPPER}_AGENT_PAT)
# GH_BACKEND=http          # 명시적 override (보통 불필요 — cwd 기반 자동 분기)

# ── Harness mode ──
# HARNESS_MODE=local  (default) — claude -p 헤드리스 (user OAuth/subscription)
# HARNESS_MODE=hermes           — raw LLM API + ReAct + plan-apply (codex/openai 등)
# 역할별 override: EXECUTOR_MODE / REVIEWER_MODE (HARNESS_MODE 보다 우선)
HARNESS_MODE=local
# EXECUTOR_MODE=hermes           # executor 만 API 모드로 (디버깅용)
# REVIEWER_MODE=hermes           # reviewer 만 API 모드로

# ── LLM provider (Hermes mode 만 사용) ──
LLM_PROVIDER=openai        # openai | anthropic
OPENAI_API_KEY=            # sk-...
ANTHROPIC_API_KEY=         # sk-ant-... (anthropic 사용 시)
ANTHROPIC_BASE_URL=        # optional: 사내 gateway

# ── 모델 (Hermes mode) ──
# ADR-012 rename: EXECUTOR_* → DEVELOPER_*. 둘 다 인식 (back-compat).
DEVELOPER_MODEL=gpt-5.3-codex
REVIEWER_MODEL=gpt-5.3-codex
DEVELOPER_COST_CAP=1.50                         # ReAct 1회 비용 cap (USD)

# ── Local mode (claude -p) ──
CLAUDE_BIN=claude                                # claude CLI 경로. default: $PATH 의 'claude'
LOCAL_CLAUDE_TIMEOUT_SEC=1800                    # claude -p 1회 최대 실행 시간 (30분)
LOCAL_PR_DESCRIPTION_SKILL=/pr-description       # commit 후 PR body 생성 스킬 (빈 값이면 developer JSON 의 pr_body 사용)

# 모델 — 역할별 default (LOCAL_<ROLE>_MODEL > LOCAL_CLAUDE_MODEL > 아래 default)
#   PO / REVIEWER / CRITIQUE → sonnet (가벼운 분석)
#   DEVELOPER                → opus   (코드 작성 — 품질 우선)
# LOCAL_CLAUDE_MODEL=opus     # 전체 override (모든 역할 동일 모델로)
# LOCAL_PO_MODEL=sonnet       # PO 만 override
# LOCAL_DEVELOPER_MODEL=opus  # developer 만 override
# LOCAL_REVIEWER_MODEL=sonnet # reviewer 만 override
# LOCAL_CRITIQUE_MODEL=sonnet # critique 만 override

# ── orchestrator ──
MAX_PARALLEL_DEVELOPERS=2     # 옛 이름 MAX_PARALLEL_EXECUTORS 도 인식
MAX_PARALLEL_REVIEWERS=2
POLL_INTERVAL=30           # ah run daemon 의 poll 주기 (Hermes cron 쓰면 무관)

# ── notification ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
