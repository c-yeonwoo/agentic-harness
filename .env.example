# ── GitHub ──
GH_TOKEN=                  # PAT — repo + write + workflow scope. project 별 PAT 도 OK (PALETTE_AGENT_PAT 등)

# ── LLM provider (Phase B 후) ──
LLM_PROVIDER=anthropic     # anthropic | openai
ANTHROPIC_API_KEY=         # sk-ant-...
ANTHROPIC_BASE_URL=        # 비워두면 default (api.anthropic.com). 빈 줄로 두지 말고 명시 X
OPENAI_API_KEY=            # sk-... (Phase B)

# ── 모델 ──
EXECUTOR_MODEL=claude-haiku-4-5-20251001       # 또는 sonnet / gpt-5
REVIEWER_MODEL=claude-haiku-4-5-20251001       # 보통 작은 모델 OK
EXECUTOR_COST_CAP=1.50                          # ReAct 1회 비용 cap (USD)

# ── orchestrator ──
MAX_PARALLEL_EXECUTORS=2
MAX_PARALLEL_REVIEWERS=2
POLL_INTERVAL=30           # ah run daemon 의 poll 주기 (Hermes cron 쓰면 무관)

# ── notification ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
